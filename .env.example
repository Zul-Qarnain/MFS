# =============================================================================
# MFS Unified — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Backend (Express)
# -----------------------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
REQUEST_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# PostgreSQL (via docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://mfs:mfs_dev_pass@localhost:5432/mfs_unified?schema=public
POSTGRES_USER=mfs
POSTGRES_PASSWORD=mfs_dev_pass
POSTGRES_DB=mfs_unified

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# PIN hashing (app-unlock PIN only — provider PINs are NEVER handled)
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Provider: bKash (Tokenized Checkout)
# -----------------------------------------------------------------------------
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_CALLBACK_URL=http://localhost:4000/payments/bkash/callback

# -----------------------------------------------------------------------------
# Provider: Nagad (sandbox — live once merchant onboarded)
# -----------------------------------------------------------------------------
NAGAD_BASE_URL=https://sandbox.mynagad.com:10061/api/dfs-service
NAGAD_MERCHANT_ID=
NAGAD_PG_PUBLIC_KEY=
NAGAD_MERCHANT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Provider: Rocket (no public API — mock in Phase B)
# -----------------------------------------------------------------------------
ROCKET_BASE_URL=https://sandbox.rocket.example.com
ROCKET_API_KEY=

# -----------------------------------------------------------------------------
# OTP / SMS gateway (SSL Wireless / MimSMS / similar)
# -----------------------------------------------------------------------------
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER_ID=MFS-Unified
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# -----------------------------------------------------------------------------
# Rate limiting (express-rate-limit + rate-limit-redis)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GLOBAL=200
RATE_LIMIT_MAX_PER_USER=60

# -----------------------------------------------------------------------------
# Observability (optional, Phase 2+)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

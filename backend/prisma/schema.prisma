// Prisma schema — MFS Unified backend
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// User
// -----------------------------------------------------------------------------
model User {
  id                  String    @id @default(uuid()) @db.Uuid
  phone               String    @unique @db.VarChar(20)
  name                String    @db.VarChar(120)
  pinHash             String?   @map("pin_hash") @db.VarChar(128)
  isPinSet            Boolean   @default(false) @map("is_pin_set")
  biometricEnabled    Boolean   @default(false) @map("biometric_enabled")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  devices             Device[]
  contacts            Contact[]
  outgoingTxns        Transaction[] @relation("OutgoingUser")
  incomingTxns        Transaction[] @relation("IncomingUser")
  otpSessions         OtpSession[]
  idempotencyKeys     IdempotencyKey[]

  @@map("users")
}

// -----------------------------------------------------------------------------
// Device (bound to an authenticated session)
// -----------------------------------------------------------------------------
model Device {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  fingerprint     String    @unique @db.VarChar(128)
  deviceName      String?   @map("device_name") @db.VarChar(80)
  platform        String    @default("android") @db.VarChar(16)
  isActive        Boolean   @default(true) @map("is_active")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

// -----------------------------------------------------------------------------
// Provider — enum (bKash / Nagad / Rocket)
// -----------------------------------------------------------------------------
enum Provider {
  BKASH
  NAGAD
  ROCKET
}

// -----------------------------------------------------------------------------
// Contact (user's address book)
// -----------------------------------------------------------------------------
model Contact {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String    @db.VarChar(120)
  phone         String    @db.VarChar(20)
  provider      Provider?
  isFavorite    Boolean   @default(false) @map("is_favorite")
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId, isFavorite])
  @@index([userId, provider])
  @@map("contacts")
}

// -----------------------------------------------------------------------------
// Transaction (payment record)
// -----------------------------------------------------------------------------
enum TransactionStatus {
  PENDING
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
}

enum TransactionType {
  MERCHANT_PAYMENT
  P2P_SEND
  CASH_OUT
  BILL_PAY
}

model Transaction {
  id                  String            @id @default(uuid()) @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  provider            Provider
  type                TransactionType
  status              TransactionStatus @default(PENDING)
  amountMinorUnits    Int               @map("amount_minor_units")
  currency            String            @default("BDT") @db.VarChar(3)
  recipientPhone      String?           @map("recipient_phone") @db.VarChar(20)
  merchantName        String?           @map("merchant_name") @db.VarChar(120)
  providerTxnId       String?           @unique @map("provider_txn_id") @db.VarChar(120)
  idempotencyKey      String            @unique @map("idempotency_key") @db.Uuid
  deviceFingerprint   String?           @map("device_fingerprint") @db.VarChar(128)
  metadata            Json?             @db.JsonB
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  user                User              @relation("OutgoingUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([providerTxnId])
  @@map("transactions")
}

// -----------------------------------------------------------------------------
// OtpSession (short-lived OTP hashes for login / registration)
// -----------------------------------------------------------------------------
model OtpSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  phone           String    @db.VarChar(20)
  purpose         String    @db.VarChar(32) // LOGIN | REGISTER | PIN_RESET
  otpHash         String    @map("otp_hash") @db.VarChar(128)
  attempts        Int       @default(0)
  expiresAt       DateTime  @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, purpose])
  @@map("otp_sessions")
}

// -----------------------------------------------------------------------------
// IdempotencyKey (de-duplication for write endpoints)
// -----------------------------------------------------------------------------
model IdempotencyKey {
  key             String    @id @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  endpoint        String    @db.VarChar(120)
  responseCode    Int       @map("response_code")
  responseBody    Json      @map("response_body") @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endpoint])
  @@map("idempotency_keys")
}
